<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Synthesis">
<meta name="theme-color" content="#0a0907">
<title>Synthesis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1710;
    --paper: #f5f1e8;
    --paper2: #ede8dc;
    --accent: #c8783a;
    --accent2: #8b4513;
    --muted: #7a7060;
    --faint: #d4cfc2;
    --signal: #2d5a27;
    --signal-bg: #f0f7ee;
    --dive-bg: #faf8f4;
    --rabbit-bg: #f7f3ef;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--ink);
    color: var(--paper);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overscroll-behavior: none;
  }

  /* ── SETUP SCREEN ── */
  #setupScreen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    background: var(--ink);
  }

  .setup-logo {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    letter-spacing: -1px;
    color: var(--paper);
    margin-bottom: 6px;
  }
  .setup-tagline {
    font-size: 13px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 48px;
  }

  .setup-card {
    background: #221e17;
    border: 0.5px solid #3a3428;
    border-radius: 16px;
    padding: 28px 24px;
    width: 100%;
    max-width: 420px;
  }

  .setup-label {
    font-size: 11px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  .setup-input {
    width: 100%;
    background: #1a1710;
    border: 0.5px solid #3a3428;
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 14px;
    font-family: 'DM Mono', monospace;
    color: var(--accent);
    outline: none;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
    transition: border-color 0.2s;
  }
  .setup-input:focus { border-color: var(--accent); }
  .setup-input::placeholder { color: #3a3428; }

  .setup-hint {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .setup-hint a { color: var(--accent); text-decoration: none; }

  .primary-btn {
    width: 100%;
    background: var(--accent);
    color: var(--ink);
    font-size: 14px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    padding: 15px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    letter-spacing: 0.02em;
  }
  .primary-btn:hover { background: #d4854a; }
  .primary-btn:active { transform: scale(0.98); }
  .primary-btn:disabled { background: #3a3428; color: var(--muted); cursor: not-allowed; }

  /* ── MAIN APP ── */
  #mainApp { display: none; min-height: 100vh; background: var(--ink); }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 9, 7, 0.95);
    backdrop-filter: blur(12px);
    padding: 16px 20px 12px;
    border-bottom: 0.5px solid #2a2420;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .topbar-logo {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--paper);
    letter-spacing: -0.5px;
  }

  .topbar-right { display: flex; align-items: center; gap: 12px; }

  .date-pill {
    font-size: 11px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.06em;
  }

  .gen-btn {
    background: var(--accent);
    color: var(--ink);
    font-size: 12px;
    font-weight: 500;
    padding: 7px 14px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .gen-btn:hover { background: #d4854a; }
  .gen-btn:disabled { background: #2a2420; color: var(--muted); cursor: not-allowed; }

  /* ── EMPTY STATE ── */
  #emptyState {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 32px;
    text-align: center;
  }

  .empty-word {
    font-family: 'Playfair Display', serif;
    font-size: 64px;
    color: #221e17;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 24px;
  }

  .empty-sub {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
    max-width: 280px;
    margin-bottom: 32px;
  }

  /* ── BRIEF CONTENT ── */
  #briefContent { display: none; padding-bottom: 80px; }

  /* SIGNAL SECTION */
  .signal-section {
    background: #0f0d09;
    border-bottom: 0.5px solid #2a2420;
    padding: 24px 20px;
  }

  .section-kicker {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-kicker::after {
    content: '';
    flex: 1;
    height: 0.5px;
    background: #2a2420;
  }

  .signal-text {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    line-height: 1.9;
    color: #d4cfc2;
    font-style: italic;
  }

  /* DEEP DIVE SECTION */
  .dives-section { padding: 0; }

  .dive-card {
    border-bottom: 0.5px solid #1e1a14;
    padding: 24px 20px;
  }

  .dive-topic {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .dive-headline {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    line-height: 1.3;
    color: var(--paper);
    margin-bottom: 14px;
    letter-spacing: -0.3px;
  }

  .dive-body {
    font-size: 15px;
    line-height: 1.85;
    color: #a89f8c;
    margin-bottom: 16px;
  }

  .dive-body .term {
    color: var(--paper);
    font-weight: 500;
    border-bottom: 0.5px solid var(--accent);
  }

  .dive-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 0.5px solid #1e1a14;
  }

  .read-link {
    font-size: 12px;
    color: var(--accent);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .read-link:hover { color: #d4854a; }

  .save-btn-small {
    background: transparent;
    border: 0.5px solid #2a2420;
    color: var(--muted);
    font-size: 11px;
    font-family: 'DM Mono', monospace;
    padding: 5px 12px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .save-btn-small:hover { border-color: var(--accent); color: var(--accent); }
  .save-btn-small.saved { border-color: var(--signal); color: var(--signal); }

  /* RABBIT HOLE */
  .rabbit-section {
    background: #0d0b08;
    padding: 28px 20px;
    border-top: 0.5px solid #2a2420;
  }

  .rabbit-label {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .rabbit-topic {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    color: var(--accent);
    font-style: italic;
    margin-bottom: 16px;
  }

  .rabbit-body {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    line-height: 2;
    color: #c4bfb0;
    font-style: italic;
  }

  /* LOADING */
  .loading-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,9,7,0.92);
    z-index: 200;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .loading-overlay.show { display: flex; }

  .loading-word {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--paper);
    opacity: 0;
    animation: fadeWord 3s infinite;
  }

  @keyframes fadeWord {
    0%, 100% { opacity: 0; }
    20%, 80% { opacity: 1; }
  }

  .loading-bar-track {
    width: 180px;
    height: 1px;
    background: #2a2420;
    position: relative;
    overflow: hidden;
    border-radius: 1px;
  }
  .loading-bar-fill {
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: var(--accent);
    animation: slide 1.5s ease-in-out infinite;
  }
  @keyframes slide { to { left: 100%; } }

  .loading-msg {
    font-size: 12px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
  }

  /* SETTINGS */
  .settings-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--muted);
    font-size: 16px;
    transition: color 0.2s;
  }
  .settings-btn:hover { color: var(--paper); }

  #settingsPanel {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,9,7,0.96);
    z-index: 300;
    overflow-y: auto;
    padding: 32px 24px;
  }

  .settings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .settings-title {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    color: var(--paper);
  }
  .close-btn {
    background: transparent;
    border: 0.5px solid #2a2420;
    color: var(--muted);
    font-size: 13px;
    padding: 6px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
  }

  .settings-section-title {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .settings-input {
    width: 100%;
    background: #1a1710;
    border: 0.5px solid #2a2420;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13px;
    font-family: 'DM Mono', monospace;
    color: var(--accent);
    outline: none;
    margin-bottom: 24px;
  }

  .notif-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 0.5px solid #1e1a14;
  }
  .notif-label { font-size: 14px; color: var(--paper); }
  .notif-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .toggle {
    width: 44px;
    height: 24px;
    background: #2a2420;
    border-radius: 12px;
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
    border: none;
  }
  .toggle.on { background: var(--accent); }
  .toggle::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    background: white;
    border-radius: 50%;
    transition: transform 0.2s;
  }
  .toggle.on::after { transform: translateX(20px); }

  /* NOTIFICATION BELL */
  .notif-badge {
    display: none;
    position: fixed;
    top: 16px;
    right: 20px;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    z-index: 50;
  }

  /* BOTTOM NAV */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(10,9,7,0.97);
    border-top: 0.5px solid #1e1a14;
    display: flex;
    padding: 10px 0 20px;
    z-index: 100;
  }
  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    padding: 6px 0;
    transition: opacity 0.2s;
  }
  .nav-icon { font-size: 18px; filter: grayscale(1); opacity: 0.4; transition: all 0.2s; }
  .nav-label { font-size: 10px; color: var(--muted); font-family: 'DM Mono', monospace; }
  .nav-item.active .nav-icon { filter: none; opacity: 1; }
  .nav-item.active .nav-label { color: var(--accent); }

  /* YOUTUBE TAB */
  #ytTab { display: none; padding: 24px 20px 80px; }

  .yt-input-wrap {
    background: #141008;
    border: 0.5px solid #2a2420;
    border-radius: 14px;
    padding: 16px;
    margin-bottom: 16px;
  }
  .yt-input {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: var(--paper);
    line-height: 1.5;
  }
  .yt-input::placeholder { color: #3a3428; }
  .yt-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 0.5px solid #1e1a14;
  }

  .yt-result { margin-top: 8px; }
  .yt-card {
    background: #0f0d09;
    border: 0.5px solid #2a2420;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .yt-card-head {
    padding: 14px 16px;
    border-bottom: 0.5px solid #1e1a14;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .yt-card-label {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .yt-card-body { padding: 16px; }
  .yt-section-head {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 14px 0 6px;
  }
  .yt-section-head:first-child { margin-top: 0; }
  .yt-bullet {
    font-size: 14px;
    color: #a89f8c;
    line-height: 1.7;
    padding: 4px 0 4px 14px;
    position: relative;
  }
  .yt-bullet::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #3a3428;
  }

  .verdict-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-family: 'DM Mono', monospace;
    margin-top: 6px;
  }
  .verdict-yes { background: #0d1a0a; color: #6db56a; border: 0.5px solid #2a4a28; }
  .verdict-no { background: #1a0d0a; color: #c46060; border: 0.5px solid #4a2a28; }

  .spinner-inline {
    width: 14px; height: 14px;
    border: 1.5px solid #2a2420;
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .error-strip {
    padding: 14px 16px;
    background: #1a0d0a;
    border: 0.5px solid #4a2a28;
    border-radius: 10px;
    font-size: 13px;
    color: #c46060;
    font-family: 'DM Mono', monospace;
    line-height: 1.6;
  }

  @media (max-width: 400px) {
    .dive-headline { font-size: 18px; }
    .signal-text { font-size: 15px; }
  }
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div id="setupScreen">
  <div class="setup-logo">Synthesis</div>
  <div class="setup-tagline">Your daily intelligence brief</div>
  <div class="setup-card">
    <label class="setup-label">Groq API Key</label>
    <input class="setup-input" type="password" id="setupKey" placeholder="gsk_..." autocomplete="off" />
    <p class="setup-hint">
      Get your key from <a href="https://console.groq.com" target="_blank">console.groq.com</a> — starts with gsk_...
    </p>
    <button class="primary-btn" onclick="startApp()">Enter Synthesis →</button>
  </div>
</div>

<!-- LOADING OVERLAY -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-word" id="loadingWord">Reading...</div>
  <div class="loading-bar-track"><div class="loading-bar-fill"></div></div>
  <div class="loading-msg" id="loadingMsg">fetching today's sources</div>
</div>

<!-- SETTINGS PANEL -->
<div id="settingsPanel">
  <div class="settings-header">
    <div class="settings-title">Settings</div>
    <button class="close-btn" onclick="closeSettings()">close</button>
  </div>

  <div class="settings-section-title" style="margin-bottom:12px;">API Key</div>
  <input class="settings-input" type="password" id="settingsKey" placeholder="gsk_..." />

  <div class="settings-section-title">Notifications</div>
  <div class="notif-row">
    <div>
      <div class="notif-label">Morning Brief</div>
      <div class="notif-sub">Daily reminder at 8:00 AM</div>
    </div>
    <button class="toggle" id="notifToggle" onclick="toggleNotifications()"></button>
  </div>

  <div class="notif-row">
    <div>
      <div class="notif-label">Notion Sync</div>
      <div class="notif-sub">Notion token (optional)</div>
    </div>
  </div>
  <input class="settings-input" type="password" id="notionToken" placeholder="secret_..." style="margin-top:10px;" />

  <button class="primary-btn" style="margin-top:8px;" onclick="saveSettings()">Save Settings</button>
</div>

<!-- MAIN APP -->
<div id="mainApp">
  <div class="topbar">
    <div class="topbar-logo">Synthesis</div>
    <div class="topbar-right">
      <div class="date-pill" id="topbarDate"></div>
      <button class="gen-btn" id="genBtn" onclick="generateBrief()">Generate Brief</button>
      <button class="settings-btn" onclick="openSettings()">⚙</button>
    </div>
  </div>

  <!-- BRIEF TAB -->
  <div id="briefTab">
    <div id="emptyState">
      <div class="empty-word">Synthesis</div>
      <div class="empty-sub">Your daily brief — curated, distilled, delivered. 10 minutes to stay sharp.</div>
      <button class="primary-btn" style="max-width:240px;" onclick="generateBrief()">Generate Today's Brief →</button>
    </div>
    <div id="briefContent"></div>
  </div>

  <!-- YOUTUBE TAB -->
  <div id="ytTab">
    <div class="yt-input-wrap">
      <input class="yt-input" type="url" id="ytUrl" placeholder="Paste a YouTube link to summarise..." />
      <div class="yt-footer">
        <button class="gen-btn" onclick="summariseYT()" id="ytBtn">Summarise</button>
      </div>
    </div>
    <div id="ytResult"></div>
  </div>

  <!-- BOTTOM NAV -->
  <div class="bottom-nav">
    <div class="nav-item active" id="nav-brief" onclick="switchTab('brief')">
      <div class="nav-icon">◈</div>
      <div class="nav-label">Brief</div>
    </div>
    <div class="nav-item" id="nav-yt" onclick="switchTab('yt')">
      <div class="nav-icon">▶</div>
      <div class="nav-label">YouTube</div>
    </div>
    <div class="nav-item" id="nav-settings" onclick="openSettings()">
      <div class="nav-icon">⚙</div>
      <div class="nav-label">Settings</div>
    </div>
  </div>
</div>

<script>
// ── STATE ──
let apiKey = '';
let notionToken = '';
let notifEnabled = false;
let currentBrief = null;

const TOPICS_ROTATION = [
  ['AI & Business', 'FMCG & Consumer', 'Supply Chain'],
  ['FMCG & Consumer', 'Supply Chain', 'Geopolitics & Macro'],
  ['Supply Chain', 'Geopolitics & Macro', 'AI & Business'],
  ['Geopolitics & Macro', 'AI & Business', 'FMCG & Consumer']
];

const CURIOUS_ROTATION = ['Game Theory', 'Mathematics', 'Space', 'Poetry', 'Art', 'Philosophy', 'Neuroscience'];

const RSS_SOURCES = {
  'AI & Business': [
    'https://api.allorigins.win/raw?url=https://deeplearning.ai/the-batch/feed/',
    'https://api.allorigins.win/raw?url=https://stratechery.com/feed/',
    'https://api.allorigins.win/raw?url=https://feeds.feedburner.com/TechnologyReview'
  ],
  'FMCG & Consumer': [
    'https://api.allorigins.win/raw?url=https://hbr.org/feed',
    'https://api.allorigins.win/raw?url=https://www.livemint.com/rss/companies',
    'https://api.allorigins.win/raw?url=https://inc42.com/feed/'
  ],
  'Supply Chain': [
    'https://api.allorigins.win/raw?url=https://www.freightwaves.com/feed',
    'https://api.allorigins.win/raw?url=https://www.mckinsey.com/capabilities/operations/our-insights/rss'
  ],
  'Geopolitics & Macro': [
    'https://api.allorigins.win/raw?url=https://www.foreignaffairs.com/rss.xml',
    'https://api.allorigins.win/raw?url=https://www.project-syndicate.org/rss',
