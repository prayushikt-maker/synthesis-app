}

function saveSettings() {
  const k = document.getElementById('settingsKey').value.trim();
  const n = document.getElementById('notionToken').value.trim();
  if (k) { apiKey = k; localStorage.setItem('synthesis_groq_key', k); }
  if (n) { notionToken = n; localStorage.setItem('synthesis_notion', n); }
