async function toggleNotifications() {
  const toggle = document.getElementById('notifToggle');
  if (!notifEnabled) {
    try {
      const perm = await Notification.requestPermission();
      if (perm === 'granted') {
        notifEnabled = true;
        toggle.classList.add('on');
        scheduleNotification();
        new Notification('Synthesis', { body: 'Morning briefs enabled. See you at 8 AM.', icon: '' });
      }
    } catch(e) { console.log('Notifications not supported'); }
  } else {
    notifEnabled = false;
    toggle.classList.remove('on');
  }
}

function scheduleNotification() {
  if (!notifEnabled) return;
  const now = new Date();
  const next8am = new Date();
  next8am.setHours(8, 0, 0, 0);
  if (next8am <= now) next8am.setDate(next8am.getDate() + 1);
  const ms = next8am - now;
  setTimeout(() => {
    if (Notification.permission === 'granted') {
      new Notification('Synthesis', { body: 'Your morning brief is ready. 10 minutes to stay sharp.' });
    }
    scheduleNotification();
  }, ms);
}

// ── RSS FETCHING ──
async function fetchRSS(url) {
  try {
    const r = await fetch(url, { signal: AbortSignal.timeout(6000) });
    const text = await r.text();
    const parser = new DOMParser();
    const xml = parser.parseFromString(text, 'text/xml');
    const items = xml.querySelectorAll('item, entry');
    const results = [];
    items.forEach((item, i) => {
      if (i >= 4) return;
      const title = item.querySelector('title')?.textContent?.trim() || '';
      const desc = (item.querySelector('description, summary, content')?.textContent || '').replace(/<[^>]*>/g, '').slice(0, 300);
      const link = item.querySelector('link')?.textContent?.trim() || item.querySelector('link')?.getAttribute('href') || '';
      const pubDate = item.querySelector('pubDate, published, updated')?.textContent?.trim() || '';
      if (title) results.push({ title, desc, link, pubDate });
    });
    return results;
  } catch(e) { return []; }
}

async function fetchTopicContent(topic) {
  const sources = RSS_SOURCES[topic] || [];
  const all = await Promise.all(sources.map(fetchRSS));
  return all.flat().slice(0, 6);
}

// ── AI ──
async function callGemini(prompt, maxTokens = 1200) {
  const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`
    },
    body: JSON.stringify({
      model: 'llama-3.3-70b-versatile',
      messages: [{ role: 'user', content: prompt }],
      max_tokens: maxTokens,
      temperature: 0.7
    })
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message || JSON.stringify(data.error));
  return data.choices[0].message.content;
}

// ── GENERATE BRIEF ──
function showLoading(msg) {
  document.getElementById('loadingOverlay').classList.add('show');
  document.getElementById('loadingMsg').textContent = msg || 'fetching sources';
  loadingWordIdx = 0;
  document.getElementById('loadingWord').textContent = LOADING_WORDS[0];
  loadingInterval = setInterval(() => {
    loadingWordIdx = (loadingWordIdx + 1) % LOADING_WORDS.length;
    document.getElementById('loadingWord').textContent = LOADING_WORDS[loadingWordIdx];
  }, 1800);
}

function hideLoading() {
  clearInterval(loadingInterval);
  document.getElementById('loadingOverlay').classList.remove('show');
}

function updateLoadingMsg(msg) {
  document.getElementById('loadingMsg').textContent = msg;
}

async function generateBrief() {
  if (!apiKey) { openSettings(); return; }
  const genBtn = document.getElementById('genBtn');
  genBtn.disabled = true;
  showLoading('fetching your sources');

  try {
    const dayOfYear = Math.floor((new Date() - new Date(new Date().getFullYear(), 0, 0)) / 86400000);
    const todayTopics = TOPICS_ROTATION[dayOfYear % 4];
    const curiousTopic = CURIOUS_ROTATION[dayOfYear % CURIOUS_ROTATION.length];
    const today = new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

    updateLoadingMsg('reading articles');

    // Fetch content in parallel
    const [t1Content, t2Content, t3Content, curContent] = await Promise.all([
      fetchTopicContent(todayTopics[0]),
      fetchTopicContent(todayTopics[1]),
      fetchTopicContent(todayTopics[2]),
      fetchTopicContent(curiousTopic)
    ]);

    const makeArticleList = (articles) =>
      articles.length > 0
        ? articles.map(a => `- ${a.title}: ${a.desc}`).join('\n')
        : '(use your knowledge of recent developments)';

    updateLoadingMsg('synthesising with AI');

    // SIGNAL
    const signalPrompt = `You are writing for an Indian MBA student (beginner level, intellectually curious). 
Today is ${today}.

Write THE SIGNAL: exactly 5 sentences. Each sentence covers one major development across these topics: ${todayTopics.join(', ')} and ${curiousTopic}. 
Written like a smart friend texting you what matters. No jargon without explanation. India angle where relevant.
Use jargon but define it inline the first time. Help build vocabulary.

Recent articles to draw from:
${makeArticleList([...t1Content.slice(0,2), ...t2Content.slice(0,2), ...t3Content.slice(0,2)])}

Output ONLY the 5 sentences, no labels, no intro.`;

    const signalText = await callGemini(signalPrompt, 400);

    updateLoadingMsg('writing deep dives');

    // DEEP DIVES
    const divePrompts = [
      { topic: todayTopics[0], articles: t1Content },
      { topic: todayTopics[1], articles: t2Content },
      { topic: todayTopics[2], articles: t3Content }
    ];

    const dives = await Promise.all(divePrompts.map(async ({ topic, articles }) => {
      const prompt = `You are writing a deep dive for an Indian MBA student. Beginner level but wants to build vocabulary — use jargon and define it inline on first use.

Topic: ${topic}
Today: ${today}

Recent articles:
${makeArticleList(articles)}

Write in this EXACT format:
HEADLINE: [one punchy headline, max 10 words]
BODY: [200 words of connected prose. Use jargon, define inline. India angle if relevant. No bullet points. Make the reader feel smarter after reading.]
LINK: [most relevant article URL from the list, or leave blank]

Output only HEADLINE, BODY, LINK with those exact labels.`;
      const raw = await callGemini(prompt, 500);
      const headline = raw.match(/HEADLINE:\s*(.+)/)?.[1]?.trim() || topic + ' Update';
      const body = raw.match(/BODY:\s*([\s\S]+?)(?=LINK:|$)/)?.[1]?.trim() || '';
      const link = raw.match(/LINK:\s*(.+)/)?.[1]?.trim() || (articles[0]?.link || '');
      return { topic, headline, body, link: link && link.startsWith('http') ? link : (articles[0]?.link || '') };
    }));

    updateLoadingMsg('finding your rabbit hole');

    // RABBIT HOLE
    const rabbitPrompt = `You are writing for a curious Indian MBA student who wants to expand their mind.

Topic today: ${curiousTopic}
${curContent.length > 0 ? 'Recent pieces: ' + makeArticleList(curContent) : ''}

Write THE RABBIT HOLE: a 150-word thought piece or story about ${curiousTopic}. 
Written as a pure observation or idea — no structure, no bullets, no headers.
Like a beautiful paragraph from a book you can't put down.
Make it surprising. Make it Indian-relevant if possible.
Use rich language. Build the reader's vocabulary naturally.

Output ONLY the paragraph.`;

    const rabbitText = await callGemini(rabbitPrompt, 350);

    hideLoading();

    // RENDER
    renderBrief({ signal: signalText, dives, rabbit: { topic: curiousTopic, text: rabbitText }, topics: todayTopics, date: today });

  } catch(e) {
    hideLoading();
    document.getElementById('briefContent').innerHTML = `<div style="padding:24px;"><div class="error-strip">Error: ${e.message}<br><br>Check your Groq API key in Settings.</div></div>`;
    document.getElementById('briefContent').style.display = 'block';
    document.getElementById('emptyState').style.display = 'none';
  }
  genBtn.disabled = false;
}

function renderBrief({ signal, dives, rabbit, topics, date }) {
  const diveHtml = dives.map(d => `
    <div class="dive-card">
      <div class="dive-topic">${d.topic}</div>
      <div class="dive-headline">${d.headline}</div>
      <div class="dive-body">${d.body}</div>
      <div class="dive-footer">
        ${d.link ? `<a class="read-link" href="${d.link}" target="_blank">Read full article →</a>` : '<span></span>'}
        <button class="save-btn-small" onclick="saveToNotion('${encodeURIComponent(d.headline)}', '${encodeURIComponent(d.body)}', '${encodeURIComponent(d.link)}', this)">Save</button>
      </div>
    </div>`).join('');

  const html = `
    <div class="signal-section">
      <div class="section-kicker">The Signal</div>
      <div class="signal-text">${signal.replace(/\n/g, ' ')}</div>
    </div>
    <div class="dives-section">
      <div style="padding:16px 20px 0; font-size:10px; font-family:'DM Mono',monospace; letter-spacing:0.15em; text-transform:uppercase; color:var(--muted);">Today's Deep Dives — ${topics.join(' · ')}</div>
      ${diveHtml}
    </div>
    <div class="rabbit-section">
      <div class="rabbit-label">The Rabbit Hole</div>
      <div class="rabbit-topic">Today: ${rabbit.topic}</div>
      <div class="rabbit-body">${rabbit.text}</div>
    </div>`;

  document.getElementById('briefContent').innerHTML = html;
  document.getElementById('briefContent').style.display = 'block';
  document.getElementById('emptyState').style.display = 'none';
  localStorage.setItem('synthesis_brief_' + todayKey(), html);
}

// ── SAVE TO NOTION ──
async function saveToNotion(headline, body, link, btn) {
  if (!notionToken) {
    btn.textContent = 'Add token in Settings';
    setTimeout(() => btn.textContent = 'Save', 2000);
    return;
  }
  btn.textContent = 'Saving...';
  btn.disabled = true;
  try {
    // Search for Reading List database
    const searchRes = await fetch('https://api.notion.com/v1/search', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${notionToken}`,
        'Notion-Version': '2022-06-28',
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ query: 'Reading List', filter: { value: 'database', property: 'object' } })
    });
    const searchData = await searchRes.json();
    const db = searchData.results?.[0];
    if (!db) throw new Error('Reading List database not found');

    await fetch('https://api.notion.com/v1/pages', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${notionToken}`,
        'Notion-Version': '2022-06-28',
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        parent: { database_id: db.id },
        properties: {
          Title: { title: [{ text: { content: decodeURIComponent(headline) } }] },
          Type: { select: { name: 'Article' } },
          Link: { url: decodeURIComponent(link) || null },
          Summary: { rich_text: [{ text: { content: decodeURIComponent(body).slice(0, 500) } }] }
        }
      })
    });
    btn.textContent = '✓ Saved';
    btn.classList.add('saved');
  } catch(e) {
    btn.textContent = 'Error';
    btn.disabled = false;
    setTimeout(() => { btn.textContent = 'Save'; btn.classList.remove('saved'); }, 2000);
  }
}

// ── YOUTUBE SUMMARISER ──
async function summariseYT() {
  const url = document.getElementById('ytUrl').value.trim();
  if (!url) return;
  if (!apiKey) { openSettings(); return; }

  const btn = document.getElementById('ytBtn');
  btn.disabled = true;
  document.getElementById('ytResult').innerHTML = `<div style="padding:20px;display:flex;align-items:center;gap:10px;color:var(--muted);font-size:13px;font-family:'DM Mono',monospace;"><div class="spinner-inline"></div>Analysing video...</div>`;

  try {
    const videoIdMatch = url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
    const videoId = videoIdMatch?.[1] || '';

    let transcript = null;
    if (videoId) {
      try {
        const r = await fetch(`https://yt.lemnoslife.com/videos?part=transcript&id=${videoId}`, { signal: AbortSignal.timeout(5000) });
        const d = await r.json();
        const items = d?.items?.[0]?.transcript?.transcriptList?.[0]?.transcript;
        if (items?.length) transcript = items.map(i => i.text).join(' ').slice(0, 10000);
      } catch(e) {}
    }

    const prompt = transcript
      ? `You are an MBA-level analyst briefing a student at ISB India. Analyse this YouTube transcript.

Respond in EXACTLY this format:
HEADLINE: [one-line summary of what this video is about]
SUMMARY:
- [key point 1]
- [key point 2]
- [key point 3]
- [key point 4]
- [key point 5]
TAKEAWAYS:
- [actionable insight 1]
- [actionable insight 2]
- [actionable insight 3]
FRAMEWORKS: [any business frameworks/concepts mentioned, comma separated, or "none"]
VERDICT: [YES — worth watching because X] or [SKIP — because X]

Transcript: ${transcript}`
      : `You are an MBA analyst. The user wants to understand this YouTube video: ${url}
Based on the URL and your knowledge, provide your best analysis in EXACTLY this format:
HEADLINE: [what this video is about]
SUMMARY:
- [likely key point 1]
- [likely key point 2]
- [likely key point 3]
TAKEAWAYS:
- [insight 1]
- [insight 2]
FRAMEWORKS: [relevant concepts]
VERDICT: [your honest take on whether it seems worth watching]`;

    const result = await callGemini(prompt, 600);

    const headline = result.match(/HEADLINE:\s*(.+)/)?.[1]?.trim() || 'Video Summary';
    const summarySection = result.match(/SUMMARY:\s*([\s\S]+?)(?=TAKEAWAYS:|$)/)?.[1] || '';
    const takeawaysSection = result.match(/TAKEAWAYS:\s*([\s\S]+?)(?=FRAMEWORKS:|VERDICT:|$)/)?.[1] || '';
    const frameworks = result.match(/FRAMEWORKS:\s*(.+)/)?.[1]?.trim() || '';
    const verdict = result.match(/VERDICT:\s*(.+)/)?.[1]?.trim() || '';

    const parseBullets = (text) => text.split('\n').filter(l => l.trim().match(/^[-•*]|^\d+\./)).map(l => l.replace(/^[-•*\d.]+\s*/, '').trim()).filter(Boolean);

    const summaryBullets = parseBullets(summarySection);
    const takeawayBullets = parseBullets(takeawaysSection);
    const isYes = verdict.toLowerCase().includes('yes') || verdict.toLowerCase().includes('worth');

    document.getElementById('ytResult').innerHTML = `
      <div class="yt-card">
        <div class="yt-card-head">
          <span class="yt-card-label">Summary</span>
          <span style="font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;">${videoId || 'video'}</span>
        </div>
        <div class="yt-card-body">
          <div style="font-family:'Playfair Display',serif;font-size:17px;color:var(--paper);line-height:1.4;margin-bottom:14px;">${headline}</div>
          <div class="yt-section-head">Key Points</div>
          ${summaryBullets.map(b => `<div class="yt-bullet">${b}</div>`).join('')}
          ${takeawayBullets.length ? `<div class="yt-section-head">Takeaways</div>${takeawayBullets.map(b => `<div class="yt-bullet">${b}</div>`).join('')}` : ''}
          ${frameworks && frameworks !== 'none' ? `<div class="yt-section-head">Frameworks</div><div class="yt-bullet">${frameworks}</div>` : ''}
          ${verdict ? `<div class="yt-section-head">Verdict</div><div class="verdict-tag ${isYes ? 'verdict-yes' : 'verdict-no'}">${verdict}</div>` : ''}
        </div>
      </div>`;
  } catch(e) {
    document.getElementById('ytResult').innerHTML = `<div class="error-strip">Error: ${e.message}. Check your OpenAI API key.</div>`;
  }
  btn.disabled = false;
}

